import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

variables = [
    "GDP_per_capita",
    "Population",
    "Life_expectancy",
    "Unemployment_rate",
    "Birth_Rate",
    "Fertility_Rate",
    "Infant_mortality",
    "Maternal_mortality_ratio",
    "CPI_Change_pct"
]

# Charger les données
df_clean = pd.read_csv("world-data-2023-clean.csv")

# Création de la figure
fig, axes = plt.subplots(3, 3, figsize=(18, 15))
axes = axes.flatten()

# Tracé des boxplots
for i, variable in enumerate(variables):
    sns.boxplot(y=df_clean[variable], ax=axes[i])
    axes[i].set_title(variable)
    axes[i].set_ylabel("")

plt.tight_layout()
plt.show()